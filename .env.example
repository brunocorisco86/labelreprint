# Configurações do Sistema de Reimpressão de Rótulos C.Vale (Modelo de Exemplo)

# Dias de validade padrão para o cálculo da Data de Vencimento (Data de Fabricação + SHELF_LIFE_DAYS)
SHELF_LIFE_DAYS=60

# Caminhos do sistema
DATABASE_PATH=data/processed/entregas_processadas.db
TEMPLATES_DIR=assets/RotulosTemplate
EXPORT_DIR=Export

# Configurações de Envio de E-mail (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_aplicativo_ou_token
SMTP_FROM_EMAIL=seu_email@gmail.com
SMTP_FROM_NAME="Reimpressão Rótulos C.Vale"

# Configurações do Raspberry Pi 3B (Ambiente de Produção)
LAN_IP=192.168.1.99
TAILSCALE_IP=100.x.y.z # Preencher com o IP do Tailscale após ativação

