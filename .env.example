# Configurações do Sistema de Reimpressão de Rótulos C.Vale (Modelo de Exemplo)

# Dias de validade padrão para o cálculo da Data de Vencimento (Data de Fabricação + SHELF_LIFE_DAYS)
SHELF_LIFE_DAYS=60

# Caminhos do sistema
DATABASE_PATH=data/processed/entregas_processadas.db
TEMPLATES_DIR=assets/RotulosTemplate
EXPORT_DIR=Export
